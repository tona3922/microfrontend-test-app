# Google OAuth2 — create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URI: http://localhost:3000/
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth2 — create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/
VITE_GITHUB_CLIENT_ID=

# GitHub token exchange proxy (required — GitHub does not support CORS on token endpoint)
# Your backend should POST to https://github.com/login/oauth/access_token and return JSON
VITE_GITHUB_TOKEN_PROXY_URL=/api/auth/github/token
